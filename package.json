{
  "name": "citei-webapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "jest",
    "e2e": "start-server-and-test dev http://localhost:5173 \"cypress open --e2e\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:unit": "npx jest __tests__/unit",
    "test:integration": "npx jest __tests__/integration",
    "test:e2e": "npx playwright test",
    "test:e2e:regression": "npx playwright test visual-regression",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:snapshots": "npx playwright test visual-regression --update-snapshots",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:ci": "cross-env CI=true npm exec playwright test --pass-with-no-tests",
    "test:e2e:install": "npm exec playwright install firefox"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "identity-obj-proxy": "^3.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "react-router": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@faker-js/faker": "^10.3.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/testing-library": "^0.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-testing-library": "^7.16.0",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "start-server-and-test": "^2.1.5",
    "storybook": "^8.6.17",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  }
}
